# GCP project (Firestore + optional GCS). Uses Application Default Credentials.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
SESSION_SECRET=change-to-a-long-random-string
FRONTEND_ORIGIN=http://localhost:5173
ALLOWLIST_EMAILS=you@example.com,friend@example.com

# Optional: leave empty to use local ./data/blobs instead of GCS
# GCS_BUCKET=your-project-freenotes-data

# Local Firestore emulator (optional): FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
PORT=3000

# AI rewrite (OpenAI-compatible chat completions). Required for “Rewrite” in the editor.
# Local: put the key in .env (never commit).
# OPENAI_API_KEY=sk-...
# Production (GCP Secret Manager): short secret id or full resource name — needs GOOGLE_CLOUD_PROJECT + SA access.
# OPENAI_API_KEY_SECRET=openai-api-key
# OPENAI_API_KEY_SECRET=projects/PROJECT_ID/secrets/openai-api-key/versions/latest
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
# AI_REWRITE_MONTHLY_CAP=50

# AI tier: DEV_GRANT_AI=1, AI_TIER_BYPASS_EMAILS, or Firestore users.plan = "ai".
# Until ENABLE_STRIPE_CHECKOUT=1, if OPENAI_API_KEY or OPENAI_API_KEY_SECRET is set, all users get AI features.
# DEV_GRANT_AI=1
# AI_TIER_BYPASS_EMAILS=you@example.com

# Stripe (when ENABLE_STRIPE_CHECKOUT=1); env vars or Secret Manager refs:
# STRIPE_SECRET_KEY_SECRET=stripe-secret-key
# STRIPE_WEBHOOK_SECRET_SECRET=stripe-webhook-secret
# Grant the runtime service account: roles/secretmanager.secretAccessor on each secret.
